{
  "buildCommand": "pnpm turbo run build --filter=@repo/web",
  "outputDirectory": "apps/web/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "apps/api/api/**/*.ts": {
      "runtime": "edge"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/apps/api/api/[[...route]]"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
